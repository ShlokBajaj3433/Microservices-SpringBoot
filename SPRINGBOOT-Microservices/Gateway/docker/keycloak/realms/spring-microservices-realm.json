{
  "realm": "spring-microservices-security-realm",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "User role"
      },
      {
        "name": "admin",
        "description": "Admin role"
      }
    ]
  },
  "users": [
    {
      "username": "user",
      "enabled": true,
      "email": "user@example.com",
      "firstName": "User",
      "lastName": "Test",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "Test",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "spring-microservices-client",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*",
        "http://localhost:9000/swagger-ui/oauth2-redirect.html",
        "http://localhost:9000/webjars/swagger-ui/oauth2-redirect.html",
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://localhost:8082/*",
        "https://oauth.pstmn.io/v1/callback"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "access.token.lifespan": "300",
        "client.secret.creation.time": "1234567890"
      },
      "secret": "secret"
    }
  ],
  "clientScopes": [
    {
      "name": "microservices",
      "description": "Microservices scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ]
}
